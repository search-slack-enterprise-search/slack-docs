{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": ["github.com"]
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Search",
      "Grep",
      "Glob",
      "LS",
      "Write(kanban/)",
      "Write(kanban/*)",
      "Write(kanban/**)",
      "Write(kanban/**/*)",
      "Write(kanban/**/*.md)",
      "Update(kanban/)",
      "Update(kanban/*)",
      "Update(kanban/**)",
      "Update(kanban/**/*)",
      "Update(kanban/**/*.md)",
      "Edit(kanban/)",
      "Edit(kanban/*)",
      "Edit(kanban/**)",
      "Edit(kanban/**/*)",
      "Edit(kanban/**/*.md)",
      "MultiEdit(kanban/)",
      "MultiEdit(kanban/*)",
      "MultiEdit(kanban/**)",
      "MultiEdit(kanban/**/*)",
      "MultiEdit(kanban/**/*.md)",
      "Write(logs/)",
      "Write(logs/*)",
      "Write(logs/**)",
      "Write(logs/**/*)",
      "Write(logs/**/*.md)",
      "Update(logs/)",
      "Update(logs/*)",
      "Update(logs/**)",
      "Update(logs/**/*)",
      "Update(logs/**/*.md)",
      "Edit(logs/)",
      "Edit(logs/*)",
      "Edit(logs/**)",
      "Edit(logs/**/*)",
      "Edit(logs/**/*.md)",
      "MultiEdit(logs/)",
      "MultiEdit(logs/*)",
      "MultiEdit(logs/**)",
      "MultiEdit(logs/**/*)",
      "MultiEdit(logs/**/*.md)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.anthropic.com)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/restrict-path.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-kanban.sh"
          }
        ]
      }
    ]
  }
}
