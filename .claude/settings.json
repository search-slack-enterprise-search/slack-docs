{
  "sandbox": {
    "network": {
      "allowedDomains": ["github.com"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Read(docs/)",
      "Read(docs/*)",
      "Read(docs/**)",
      "Read(docs/**/*)",
      "Read(kanban/)",
      "Read(kanban/*)",
      "Read(kanban/**)",
      "Read(kanban/**/*)",
      "Write(kanban/)",
      "Write(kanban/*)",
      "Write(kanban/**)",
      "Write(kanban/**/*)",
      "Update(kanban/)",
      "Update(kanban/*)",
      "Update(kanban/**)",
      "Update(kanban/**/*)",
      "Edit(kanban/)",
      "Edit(kanban/*)",
      "Edit(kanban/**)",
      "Edit(kanban/**/*)",
      "MultiEdit(kanban/)",
      "MultiEdit(kanban/*)",
      "MultiEdit(kanban/**)",
      "MultiEdit(kanban/**/*)",
      "Read(logs/)",
      "Read(logs/*)",
      "Read(logs/**)",
      "Read(logs/**/*)",
      "Write(logs/)",
      "Write(logs/*)",
      "Write(logs/**)",
      "Write(logs/**/*)",
      "Update(logs/)",
      "Update(logs/*)",
      "Update(logs/**)",
      "Update(logs/**/*)",
      "Edit(logs/)",
      "Edit(logs/*)",
      "Edit(logs/**)",
      "Edit(logs/**/*)",
      "MultiEdit(logs/)",
      "MultiEdit(logs/*)",
      "MultiEdit(logs/**)",
      "MultiEdit(logs/**/*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-kanban.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(Edit|Write)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sync-agents-md.sh"
          }
        ]
      }
    ]
  }
}
