{
  "sandbox": {
    "network": {
      "allowedDomains": ["github.com"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Read(docs/**)",
      "Read(docs/**/*)",
      "Write(kanban/**)",
      "Update(kanban/**)",
      "Write(logs/**)",
      "Update(logs/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-kanban.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(Edit|Write)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sync-agents-md.sh"
          }
        ]
      }
    ]
  }
}
